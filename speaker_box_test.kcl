/*
Generated by Text-to-CAD:
A simple rectangular speaker enclosure box, 150mm high, 100mm wide, and 100mm deep, with a 75mm circular cutout in the center of the front face.
*/
@settings(defaultLengthUnit = mm)

// Parameters
height = 150
width = 100
depth = 100
cutoutDia = 75

// Base box
sketch = startSketchOn(XY)
profile = startProfile(sketch, at = [-width / 2, -height / 2])
  |> xLine(length = width)
  |> yLine(length = height)
  |> xLine(length = -width)
  |> close()
box = extrude(
  profile,
  length = depth,
  tagStart = $frontFace,
  tagEnd = $backFace,
)

// Speaker cutout (centered on the front face)
// Sketch on the front face and extrude NEGATIVELY so it cuts into the box from the front.
cutSketch = startSketchOn(box, face = frontFace)
cutCircle = circle(cutSketch, center = [0, 0], diameter = cutoutDia)
// Use MERGE (default) and a negative length to subtract material from the existing box.
enclosure = extrude(cutCircle, length = -depth)
